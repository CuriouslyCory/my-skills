# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# ---------- Authentication ----------

# JWT signing secret. You can generate one via 'openssl rand -base64 32' on Unix.
# Falls back to a hardcoded dev secret if unset — set this in production.
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# Optional: set both to enable simple username/password auth.
# When ADMIN_USER is unset, authentication is disabled entirely.
ADMIN_USER=''
ADMIN_PASSWORD=''

# ---------- Database ----------

# Path to the SQLite database file (default: ./data/my-skills.db)
DB_PATH='./data/my-skills.db'

# ---------- Web App ----------

# Absolute path to the repository root. Used by the web app to locate skill files.
# Falls back to resolve(cwd(), "../..") if unset.
REPO_PATH=''

# ---------- CLI Overrides ----------

# Override the default cache directory used by the CLI (default: XDG cache dir)
# MY_SKILLS_CACHE_DIR=''

# Override the default skills directory used by the CLI (default: XDG data dir)
# MY_SKILLS_SKILLS_DIR=''
