{
  "name": "my-skills",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @curiouslycory/web...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "ralph": "STORIES=$(jq '.userStories | length' .agents/skills/ralph/scripts/prd.json) && .agents/skills/ralph/scripts/ralph.sh $((STORIES + 4))",
    "test": "turbo run test",
    "ms": "ms",
    "my-skills": "my-skills",
    "publish:cli": "pnpm --filter ./apps/cli publish"
  },
  "devDependencies": {
    "@curiouslycory/prettier-config": "workspace:*",
    "@inquirer/confirm": "^6.0.10",
    "@inquirer/input": "^5.0.10",
    "@turbo/gen": "^2.5.8",
    "@types/node": "catalog:",
    "dotenv-cli": "^10.0.0",
    "happy": "^1.0.2",
    "prettier": "catalog:",
    "smol-toml": "^1.6.0",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "prettier": "@curiouslycory/prettier-config"
}
