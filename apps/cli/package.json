{
  "name": "my-skills",
  "version": "1.3.0",
  "type": "module",
  "files": [
    "dist/"
  ],
  "bin": {
    "ms": "dist/bin/my-skills.js",
    "my-skills": "dist/bin/my-skills.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/CuriouslyCory/my-skills"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "prepublishOnly": "pnpm run build && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@inquirer/checkbox": "^4.1.5",
    "@inquirer/confirm": "^6.0.10",
    "@inquirer/input": "^5.0.10",
    "@inquirer/search": "^3.0.12",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@curiouslycory/eslint-config": "workspace:*",
    "@curiouslycory/git-service": "workspace:*",
    "@curiouslycory/prettier-config": "workspace:*",
    "@curiouslycory/shared-types": "workspace:*",
    "@curiouslycory/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "^8.5.0",
    "typescript": "catalog:",
    "vitest": "^3.2.3"
  },
  "prettier": "@curiouslycory/prettier-config"
}
